{
  "name": "eu.ansvar/defense-aerospace-mcp",
  "displayName": "Defense / Aerospace MCP",
  "version": "1.2.0",
  "description": "Defense and aerospace domain intelligence MCP for compliance, threat modeling, and control/evidence planning.",
  "repository": "https://github.com/Ansvar-Systems/Defense-Aerospace-MCP",
  "license": "MIT",
  "runtime": "node",
  "tools": [
    "about",
    "list_sources",
    "list_jurisdiction_profiles",
    "get_jurisdiction_profile",
    "get_coverage_matrix",
    "get_expertise_scorecard",
    "list_expert_playbooks",
    "get_expert_playbook",
    "list_clause_references",
    "get_clause_reference",
    "list_architecture_patterns",
    "get_architecture_pattern",
    "classify_data",
    "get_domain_threats",
    "assess_applicability",
    "map_to_technical_standards",
    "search_domain_knowledge",
    "compare_jurisdictions",
    "build_control_baseline",
    "build_evidence_plan",
    "assess_breach_obligations",
    "create_remediation_backlog",
    "determine_cmmc_level",
    "classify_export_control",
    "assess_classified_environment",
    "assess_nato_interoperability",
    "check_data_freshness"
  ],
  "transports": [
    "stdio",
    "streamable-http"
  ],
  "entrypoints": {
    "stdio": {
      "command": "npx",
      "args": [
        "@ansvar/defense-aerospace-mcp"
      ]
    },
    "http": {
      "path": "/mcp",
      "health": "/health"
    }
  }
}
